{
	"name": "p1-front-web",
	"private": true,
	"version": "0.0.258",
	"type": "module",
	"browserslist": [
		">= 1%",
		"last 2 versions",
		"not dead",
		"not ie <= 11",
		"not op_mini all",
		"Chrome >= 100",
		"Firefox >= 102",
		"Safari >= 15.6",
		"Edge >= 100"
	],
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@playwright/test": "workspace:*",
		"@sveltejs/vite-plugin-svelte": "workspace:*",
		"@testing-library/jest-dom": "workspace:*",
		"@testing-library/svelte": "workspace:*",
		"jsdom": "workspace:*",
		"p1-front-box": "workspace:*",
		"p1-front-configs": "workspace:*",
		"prettier-plugin-svelte": "workspace:*",
		"svelte": "workspace:*",
		"svelte-check": "workspace:*",
		"svelte-preprocess": "workspace:*",
		"vite-bundle-analyzer": "workspace:*",
		"vite-plugin-build-metadata": "workspace:*",
		"vite-plugin-pwa": "workspace:*"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"svelte-preprocess"
		]
	}
}
